# ─── Server ───
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── PostgreSQL ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/leadgen

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── Security ───
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PEPPER=CHANGE_ME_TO_A_64_CHAR_HEX_SECRET
SESSION_COOKIE_NAME=__session

# ─── Email (SMTP) ───
# Option A — Local dev with Mailpit (docker compose includes it)
#   View caught emails at: http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@leadgen.local
SMTP_SECURE=false

# Option B — Mailtrap Email Sending (production / staging)
# SMTP_HOST=live.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=api
# SMTP_PASS=<YOUR_MAILTRAP_API_TOKEN>
# SMTP_FROM=<YOUR_VERIFIED_SENDER_EMAIL>
# SMTP_SECURE=false

# ─── IP Intelligence (required for risk engine) ───
# Get from: ipinfo.io → dashboard homepage → Access Token
IPINFO_TOKEN=
# Get from: abuseipdb.com → Account → API tab → Create Key
ABUSEIPDB_API_KEY=

# ─── Risk Thresholds ───
RISK_MEDIUM_THRESHOLD=30
RISK_HIGH_THRESHOLD=60
RISK_CRITICAL_THRESHOLD=90
